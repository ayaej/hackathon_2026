# Configuration de l'environnement

# Chemin vers les binaires de Poppler (requis pour PDF -> Images)
# Windows : C:\chemin\vers\poppler-xx\Library\bin
# Linux/macOS : Généralement non requis si installé via package manager (apt, brew)
POPPLER_PATH=

# Dossiers de données
# DATA_DIR=data
# RAW_DIR=data/raw
# SILVER_DIR=data/silver
# CURATED_DIR=data/curated
# PDF_DIR=pdf

# Fichiers
# DATASET_JSON=dataset.json
# SIRENE_CSV=data/raw/sirene_sample.csv
# VALIDATION_LOG=validation.log
