# Ignorer tout ce qui est dans le dossier data
data/raw/*
data/silver/*
data/gold/*

# Garder les dossiers vides sur Git en utilisant des fichiers .gitkeep
!data/raw/.gitkeep
!data/silver/.gitkeep
!data/gold/.gitkeep

# Ignorer les environnements virtuels et fichiers temporaires
venv/
__pycache__/
*.pyc
.env
.github
simu/
airflow/logs/
airflow/dags/__pycache__/

backend/node_modules/
backend/.env
backend/uploads/
frontend/node_modules/
frontend/dist/
.DS_Store

data/*.json
data/archive/
data/output/